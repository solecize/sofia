# Build artifacts
bin/
build/
*.o
*.a

# Editor/IDE
.vscode/
.idea/
*.swp
*.swo
*~

# macOS
.DS_Store

# Python (archived)
__pycache__/
*.pyc
*.pyo

# ChatGPT exports (large binary files)
notes/incoming/notes-download-*/

# Manuscript files (large, user-specific)
notes/incoming/error-correction-current-draft/

# Generated prompts (can be regenerated)
notes/wiki/*/prompts/

# Scrivener projects
*.scriv/
*.scrivx
*.dat

# Binary media in user content directories only
corpus/**/*.png
corpus/**/*.jpg
corpus/**/*.jpeg
corpus/**/*.gif
corpus/**/*.wav
corpus/**/*.mp3
corpus/**/*.mp4
notes/**/*.png
notes/**/*.jpg
notes/**/*.jpeg
notes/**/*.gif
notes/**/*.wav
notes/**/*.mp3
notes/**/*.mp4

# Include project assets (documentation, app icons)
!assets/**
!SofiaMonitor/**/*.png
!SofiaMonitor/**/*.svg
!SofiaMonitor/**/*.icns
