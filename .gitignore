corpus/**/*.png
corpus/**/*.jpg
corpus/**/*.jpeg
corpus/**/*.gif
corpus/**/*.wav
corpus/**/*.mp3
corpus/**/*.mp4
notes/**/*.png
notes/**/*.jpg
notes/**/*.jpeg
notes/**/*.gif
notes/**/*.wav
notes/**/*.mp3
notes/**/*.mp4

