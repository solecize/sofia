#!/bin/bash
# sofia-ingest: Split a manuscript into chapters and prepare for entity extraction
# Usage: sofia-ingest <manuscript.txt> --output <dir>

SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"

show_usage() {
    echo "Usage: sofia-ingest <manuscript.txt> [options]"
    echo ""
    echo "Options:"
    echo "  --output <dir>    Output directory for chapters (default: chapters/)"
    echo "  --list            List detected chapters without extracting"
    echo ""
    echo "Splits a manuscript into individual chapter files for processing."
    echo "Detects chapter markers: ===CHAPTER X===, 0x00 //Title, N: Title"
}

if [ $# -lt 1 ]; then
    show_usage
    exit 1
fi

INPUT=""
OUTPUT_DIR="chapters"
LIST_ONLY=false

while [ $# -gt 0 ]; do
    case "$1" in
        --output)
            OUTPUT_DIR="$2"
            shift 2
            ;;
        --list)
            LIST_ONLY=true
            shift
            ;;
        -*)
            echo "Unknown option: $1"
            show_usage
            exit 1
            ;;
        *)
            INPUT="$1"
            shift
            ;;
    esac
done

if [ ! -f "$INPUT" ]; then
    echo "Error: File not found: $INPUT"
    exit 1
fi

# Create output directory if extracting
if [ "$LIST_ONLY" = "false" ]; then
    mkdir -p "$OUTPUT_DIR"
fi

# Use awk to split on chapter markers (===CHAPTER X===)
awk -v OUTDIR="$OUTPUT_DIR" -v LIST_ONLY="$LIST_ONLY" '
BEGIN { chapter_num = 0; in_chapter = 0; content = ""; in_separator = 0 }

/^=+$/ { 
    in_separator = 1
    next
}

in_separator && /CHAPTER/ {
    # Save previous chapter
    if (in_chapter && length(content) > 100) {
        gsub(/[^a-z0-9]+/, "-", slug)
        gsub(/^-+|-+$/, "", slug)
        if (LIST_ONLY == "true") {
            printf "%02d: %s\n", chapter_num, title
        } else {
            filename = sprintf("%s/%02d-%s.md", OUTDIR, chapter_num, slug)
            print "# " title > filename
            print "" >> filename
            print content >> filename
            close(filename)
            print "Wrote: " filename
        }
    }
    
    chapter_num++
    gsub(/^[[:space:]]+|[[:space:]]+$/, "")
    title = $0
    slug = tolower($0)
    content = ""
    in_chapter = 1
    in_separator = 0
    next
}

in_separator { 
    if (in_chapter) content = content "======\n"
    in_separator = 0
}

/^=+$/ && in_chapter {
    next
}

in_chapter {
    content = content $0 "\n"
}

END {
    if (in_chapter && length(content) > 100) {
        gsub(/[^a-z0-9]+/, "-", slug)
        gsub(/^-+|-+$/, "", slug)
        if (LIST_ONLY == "true") {
            printf "%02d: %s\n", chapter_num, title
        } else {
            filename = sprintf("%s/%02d-%s.md", OUTDIR, chapter_num, slug)
            print "# " title > filename
            print "" >> filename
            print content >> filename
            close(filename)
            print "Wrote: " filename
        }
    }
    if (LIST_ONLY != "true") {
        print "\nExtracted " chapter_num " chapters to " OUTDIR "/"
    }
}
' "$INPUT"
