#!/bin/bash
# sofia-ingest: Split a manuscript into chapters and prepare for entity extraction
# Usage: sofia-ingest <manuscript.txt> --output <dir>

SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"

show_usage() {
    echo "Usage: sofia-ingest <manuscript.txt> [options]"
    echo ""
    echo "Options:"
    echo "  --output <dir>    Output directory for chapters (default: chapters/)"
    echo "  --list            List detected chapters without extracting"
    echo ""
    echo "Splits a manuscript into individual chapter files for processing."
}

if [ $# -lt 1 ]; then
    show_usage
    exit 1
fi

INPUT=""
OUTPUT_DIR="chapters"
LIST_ONLY=false

while [ $# -gt 0 ]; do
    case "$1" in
        --output)
            OUTPUT_DIR="$2"
            shift 2
            ;;
        --list)
            LIST_ONLY=true
            shift
            ;;
        -*)
            echo "Unknown option: $1"
            show_usage
            exit 1
            ;;
        *)
            INPUT="$1"
            shift
            ;;
    esac
done

if [ ! -f "$INPUT" ]; then
    echo "Error: File not found: $INPUT"
    exit 1
fi

# Use awk to split on chapter markers
# Patterns: "0x00 //Title", "31: Title", "Act N / Title"
awk -v output_dir="$OUTPUT_DIR" -v list_only="$LIST_ONLY" '
BEGIN {
    chapter_num = 0
    current_chapter = ""
    current_title = ""
    current_content = ""
    in_chapter = 0
}

# Match Act headers
/^[[:space:]]*Act [0-9]+ \// {
    # Save previous chapter
    if (in_chapter && length(current_content) > 100) {
        if (list_only == "true") {
            printf "%02d: %s\n", chapter_num, current_title
        } else {
            filename = sprintf("%s/%02d-%s.md", output_dir, chapter_num, current_chapter)
            print "# " current_title "\n" > filename
            print current_content >> filename
            close(filename)
            print "Wrote: " filename
        }
    }
    
    chapter_num++
    gsub(/^[[:space:]]+|[[:space:]]+$/, "", $0)
    current_title = $0
    current_chapter = tolower($0)
    gsub(/[^a-z0-9]+/, "-", current_chapter)
    gsub(/^-+|-+$/, "", current_chapter)
    current_content = ""
    in_chapter = 1
    next
}

# Match 0x00 //Title format
/^[[:space:]]*0x[0-9A-Fa-f]+ \/\// {
    # Save previous chapter
    if (in_chapter && length(current_content) > 100) {
        if (list_only == "true") {
            printf "%02d: %s\n", chapter_num, current_title
        } else {
            filename = sprintf("%s/%02d-%s.md", output_dir, chapter_num, current_chapter)
            print "# " current_title "\n" > filename
            print current_content >> filename
            close(filename)
            print "Wrote: " filename
        }
    }
    
    chapter_num++
    gsub(/^[[:space:]]+|[[:space:]]+$/, "", $0)
    current_title = $0
    # Extract just the title part after //
    idx = index($0, "//")
    if (idx > 0) {
        current_chapter = tolower(substr($0, idx + 2))
    } else {
        current_chapter = tolower($0)
    }
    gsub(/[^a-z0-9]+/, "-", current_chapter)
    gsub(/^-+|-+$/, "", current_chapter)
    current_content = ""
    in_chapter = 1
    next
}

# Match "31: Title" format
/^[[:space:]]*[0-9]+:[[:space:]]+[A-Za-z]/ {
    # Save previous chapter
    if (in_chapter && length(current_content) > 100) {
        if (list_only == "true") {
            printf "%02d: %s\n", chapter_num, current_title
        } else {
            filename = sprintf("%s/%02d-%s.md", output_dir, chapter_num, current_chapter)
            print "# " current_title "\n" > filename
            print current_content >> filename
            close(filename)
            print "Wrote: " filename
        }
    }
    
    chapter_num++
    gsub(/^[[:space:]]+|[[:space:]]+$/, "", $0)
    current_title = $0
    # Extract title after the number and colon
    idx = index($0, ":")
    if (idx > 0) {
        current_chapter = tolower(substr($0, idx + 1))
        gsub(/^[[:space:]]+/, "", current_chapter)
    } else {
        current_chapter = tolower($0)
    }
    gsub(/[^a-z0-9]+/, "-", current_chapter)
    gsub(/^-+|-+$/, "", current_chapter)
    current_content = ""
    in_chapter = 1
    next
}

# Accumulate content
in_chapter {
    current_content = current_content $0 "\n"
}

END {
    # Save last chapter
    if (in_chapter && length(current_content) > 100) {
        if (list_only == "true") {
            printf "%02d: %s\n", chapter_num, current_title
        } else {
            filename = sprintf("%s/%02d-%s.md", output_dir, chapter_num, current_chapter)
            print "# " current_title "\n" > filename
            print current_content >> filename
            close(filename)
            print "Wrote: " filename
        }
    }
    
    if (list_only != "true") {
        print "\nExtracted " chapter_num " chapters to " output_dir "/"
    }
}
' "$INPUT"

if [ "$LIST_ONLY" = "false" ]; then
    mkdir -p "$OUTPUT_DIR"
    # Re-run to actually create files (awk already did this but mkdir ensures dir exists)
fi
