#!/bin/bash
# sofia-wiki: Wiki management commands for story projects
# Usage: sofia-wiki <command> [options]

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
WIKI_ROOT="notes/wiki"
CANON_ROOT="notes/canon"
INCOMING_ROOT="notes/incoming"

# Global flags
JSON_OUTPUT="false"

# ============================================================================
# JSON Output Helpers
# ============================================================================

# Emit a JSON instruction block for Windsurf
# Usage: emit_json "ui message" "ask_json_or_null" "data_json" "next_cmd" "auto_bool"
emit_json() {
    local ui="$1"
    local ask="$2"      # JSON object or "null"
    local data="$3"     # JSON object
    local next_cmd="$4"
    local auto="$5"     # "true" or "false"
    
    # Default auto to true for hygiene tasks
    [ -z "$auto" ] && auto="true"
    
    # Convert "null" string to Python None, and bool strings to Python bools
    local ask_py="$ask"
    [ "$ask" = "null" ] && ask_py="None"
    
    local auto_py="True"
    [ "$auto" = "false" ] && auto_py="False"
    
    # Build the JSON
    python3 -c "
import json

ui = '''$ui'''
ask = $ask_py
data = $data
next_cmd = '''$next_cmd'''
auto = $auto_py

obj = {
    'ui': ui,
    'ask': ask,
    'data': data,
    'next': {
        'cmd': next_cmd,
        'auto': auto
    } if next_cmd else None
}
print(json.dumps(obj, indent=2))
"
}

# Emit a simple status JSON (auto-proceed)
emit_status_json() {
    local ui="$1"
    local data="$2"
    local next_cmd="$3"
    emit_json "$ui" "null" "$data" "$next_cmd" "true"
}

# Emit a decision-required JSON
emit_ask_json() {
    local ui="$1"
    local ask_type="$2"      # "choice", "confirm", "input"
    local question="$3"
    local options="$4"       # JSON array like ["opt1", "opt2"]
    local default="$5"
    local data="$6"
    local next_cmd="$7"
    
    local ask_obj="{\"type\": \"$ask_type\", \"question\": \"$question\", \"options\": $options, \"default\": \"$default\"}"
    emit_json "$ui" "$ask_obj" "$data" "$next_cmd" "false"
}

show_usage() {
    echo "Usage: sofia-wiki <command> [options]"
    echo ""
    echo "Commands:"
    echo "  ingest <project> <manuscript>   Bulk import manuscript into wiki"
    echo "  update <project> <notes...>     Add new notes to existing wiki"
    echo "  sync <project>                  Review and resolve conflicts"
    echo "  status <project>                Show wiki status and pending items"
    echo "  extract <project> <chapter>     Generate LLM prompt for a chapter"
    echo "  loop <project>                  Start LLM-in-the-loop workflow"
    echo "  entities <project>              List known entity names"
    echo "  validate <project> [chapter]    Validate entity naming consistency"
    echo "  align <project> <old> <new>     Align entity name variants"
    echo "  deprecate <project> <old>       Register old name for auto-alignment"
    echo ""
    echo "Options:"
    echo "  --json                          Output JSON instruction blocks"
    echo "  --dry-run                       Show what would be done without doing it"
    echo "  --no-commit                     Skip git commits"
    echo "  --deprecate                     Register old name as previous (with align)"
    echo "  --canonical <name>              Specify canonical name (with deprecate)"
    echo ""
    echo "Examples:"
    echo "  sofia-wiki ingest error-correction manuscript.txt"
    echo "  sofia-wiki update error-correction notes/new-note.md"
    echo "  sofia-wiki sync error-correction"
    echo "  sofia-wiki status error-correction"
    echo "  sofia-wiki loop error-correction --json"
    echo "  sofia-wiki align error-correction 'Mara Ivanova' 'Mara Vasenkova' --deprecate"
    echo "  sofia-wiki deprecate error-correction 'Mara Ivanova' --canonical 'Mara Vasenkova'"
}

# Ensure project wiki exists
ensure_wiki() {
    local project="$1"
    local wiki_dir="$WIKI_ROOT/$project"
    
    if [ ! -d "$wiki_dir" ]; then
        echo "Creating wiki for project: $project"
        mkdir -p "$wiki_dir"/{people,places,events,objects,ideas,chapters,.sofia}
        
        # Create config
        cat > "$wiki_dir/.sofia/config.json" << EOF
{
  "version": "1.0",
  "project": "$project",
  "created": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "settings": {
    "autoExtract": true,
    "conflictDetection": "automatic",
    "chunkGranularity": "per-field",
    "commitOnIngest": true,
    "commitOnUpdate": true
  }
}
EOF
        
        # Create empty metadata files
        echo '{"version": "1.0", "entities": {}}' > "$wiki_dir/.sofia/entities.json"
        echo '{"version": "1.0", "chunks": {}}' > "$wiki_dir/.sofia/chunks.json"
        echo '{"version": "1.0", "conflicts": {}}' > "$wiki_dir/.sofia/conflicts.json"
        echo '{"version": "1.0", "decisions": {}}' > "$wiki_dir/.sofia/decisions.json"
        
        echo "Wiki created at: $wiki_dir"
    fi
}

# Ingest command: bulk import manuscript
cmd_ingest() {
    local project="$1"
    local manuscript="$2"
    local dry_run="$3"
    local no_commit="$4"
    
    if [ -z "$project" ] || [ -z "$manuscript" ]; then
        echo "Error: ingest requires <project> and <manuscript>"
        echo "Usage: sofia-wiki ingest <project> <manuscript>"
        exit 1
    fi
    
    if [ ! -f "$manuscript" ]; then
        echo "Error: Manuscript not found: $manuscript"
        exit 1
    fi
    
    echo "=== Sofia Wiki Ingest ==="
    echo "Project: $project"
    echo "Manuscript: $manuscript"
    echo ""
    
    # Ensure wiki exists
    ensure_wiki "$project"
    
    local wiki_dir="$WIKI_ROOT/$project"
    local canon_dir="$CANON_ROOT/$project/chapters"
    
    # Step 1: Split manuscript into chapters
    echo "Step 1: Splitting manuscript into chapters..."
    mkdir -p "$canon_dir"
    
    if [ "$dry_run" = "true" ]; then
        echo "[DRY RUN] Would run: sofia-ingest \"$manuscript\" --output \"$canon_dir\""
        "$SCRIPT_DIR/scripts/sofia-ingest" "$manuscript" --list
    else
        "$SCRIPT_DIR/scripts/sofia-ingest" "$manuscript" --output "$canon_dir"
        
        # Commit canon chapters
        if [ "$no_commit" != "true" ]; then
            echo ""
            echo "Committing canon chapters..."
            cd "$SCRIPT_DIR"
            git add "$canon_dir"
            git commit -m "sofia: ingest canon chapters for $project" || echo "Nothing to commit"
        fi
    fi
    
    # Step 2: Count chapters
    local chapter_count=$(ls -1 "$canon_dir"/*.md 2>/dev/null | wc -l | tr -d ' ')
    echo ""
    echo "Step 2: Found $chapter_count chapters"
    
    # Step 3: Generate extraction prompts
    echo ""
    echo "Step 3: Entity extraction"
    echo ""
    echo "To extract entities from each chapter, run:"
    echo ""
    for chapter in "$canon_dir"/*.md; do
        local basename=$(basename "$chapter" .md)
        echo "  sofia-wiki extract $project $basename"
    done | head -10
    echo "  ..."
    echo ""
    echo "Or process all chapters:"
    echo "  for ch in $canon_dir/*.md; do"
    echo "    sofia-prompt -extract \"\$ch\" > /tmp/prompt.txt"
    echo "    # Send to LLM, save response to wiki"
    echo "  done"
    echo ""
    echo "=== Ingest Complete ==="
    echo "Canon chapters: $canon_dir"
    echo "Wiki directory: $wiki_dir"
}

# Extract command: generate LLM prompt for a chapter
cmd_extract() {
    local project="$1"
    local chapter="$2"
    
    if [ -z "$project" ] || [ -z "$chapter" ]; then
        echo "Error: extract requires <project> and <chapter>"
        echo "Usage: sofia-wiki extract <project> <chapter>"
        exit 1
    fi
    
    local canon_dir="$CANON_ROOT/$project/chapters"
    local chapter_file="$canon_dir/$chapter.md"
    
    if [ ! -f "$chapter_file" ]; then
        # Try without .md
        chapter_file="$canon_dir/$chapter"
        if [ ! -f "$chapter_file" ]; then
            echo "Error: Chapter not found: $chapter"
            echo "Available chapters:"
            ls -1 "$canon_dir"/*.md 2>/dev/null | head -10
            exit 1
        fi
    fi
    
    # Generate the extraction prompt
    "$SCRIPT_DIR/scripts/sofia-prompt" -extract "$chapter_file"
}

# Status command: show wiki status
cmd_status() {
    local project="$1"
    
    if [ -z "$project" ]; then
        if [ "$JSON_OUTPUT" = "true" ]; then
            emit_json "Error: status requires <project>" "null" '{"error": "missing_project"}' "" "false"
        else
            echo "Error: status requires <project>"
            echo "Usage: sofia-wiki status <project>"
        fi
        exit 1
    fi
    
    local wiki_dir="$WIKI_ROOT/$project"
    local canon_dir="$CANON_ROOT/$project/chapters"
    
    if [ ! -d "$wiki_dir" ]; then
        if [ "$JSON_OUTPUT" = "true" ]; then
            emit_json "Wiki not found for project: $project" "null" "{\"error\": \"wiki_not_found\", \"project\": \"$project\"}" "" "false"
        else
            echo "Error: Wiki not found for project: $project"
        fi
        exit 1
    fi
    
    # Count items
    local canon_chapters=$(ls -1 "$canon_dir"/*.md 2>/dev/null | wc -l | tr -d ' ')
    local wiki_chapters=$(ls -1 "$wiki_dir/chapters"/*.md 2>/dev/null | grep -v index.md | wc -l | tr -d ' ')
    local people=$(ls -1 "$wiki_dir/people"/*.md 2>/dev/null | grep -v index.md | wc -l | tr -d ' ')
    local places=$(ls -1 "$wiki_dir/places"/*.md 2>/dev/null | grep -v index.md | wc -l | tr -d ' ')
    local events=$(ls -1 "$wiki_dir/events"/*.md 2>/dev/null | grep -v index.md | wc -l | tr -d ' ')
    local objects=$(ls -1 "$wiki_dir/objects"/*.md 2>/dev/null | grep -v index.md | wc -l | tr -d ' ')
    local ideas=$(ls -1 "$wiki_dir/ideas"/*.md 2>/dev/null | grep -v index.md | wc -l | tr -d ' ')
    
    # Check for conflicts
    local conflicts=0
    if [ -f "$wiki_dir/.sofia/conflicts.json" ]; then
        conflicts=$(grep -c '"status": "unresolved"' "$wiki_dir/.sofia/conflicts.json" 2>/dev/null || true)
        conflicts=${conflicts:-0}
    fi
    
    # Pending chapters
    local pending=$((canon_chapters - wiki_chapters))
    local next_chapter=""
    if [ "$pending" -gt 0 ]; then
        next_chapter=$(ls -1 "$canon_dir"/*.md 2>/dev/null | while read f; do
            bn=$(basename "$f" .md)
            if [ ! -f "$wiki_dir/chapters/$bn.md" ]; then
                echo "$bn"
                break
            fi
        done)
    fi
    
    if [ "$JSON_OUTPUT" = "true" ]; then
        local data_json="{\"stage\": \"status\", \"project\": \"$project\", \"canon_chapters\": $canon_chapters, \"wiki_chapters\": $wiki_chapters, \"pending\": $pending, \"entities\": {\"people\": $people, \"places\": $places, \"events\": $events, \"objects\": $objects, \"ideas\": $ideas}, \"conflicts\": $conflicts, \"next_chapter\": \"$next_chapter\"}"
        
        local next_cmd=""
        if [ "$pending" -gt 0 ]; then
            next_cmd="sofia-wiki extract $project $next_chapter --json"
        elif [ "$conflicts" -gt 0 ]; then
            next_cmd="sofia-wiki sync $project --json"
        else
            next_cmd="sofia-wiki validate $project --json"
        fi
        
        emit_status_json "Wiki status for '$project': $wiki_chapters/$canon_chapters chapters, $pending pending, $conflicts conflicts" "$data_json" "$next_cmd"
    else
        echo "=== Sofia Wiki Status: $project ==="
        echo ""
        echo "Canon chapters:  $canon_chapters"
        echo "Wiki chapters:   $wiki_chapters / $canon_chapters"
        echo ""
        echo "Entities:"
        echo "  People:  $people"
        echo "  Places:  $places"
        echo "  Events:  $events"
        echo "  Objects: $objects"
        echo "  Ideas:   $ideas"
        echo ""
        
        if [ "$conflicts" -gt 0 ] 2>/dev/null; then
            echo "⚠️  Unresolved conflicts: $conflicts"
            echo "   Run: sofia-wiki sync $project"
        else
            echo "✓ No unresolved conflicts"
        fi
        echo ""
        
        if [ "$pending" -gt 0 ]; then
            echo "📝 Pending chapters: $pending"
            echo "   Next: sofia-wiki extract $project $next_chapter"
        fi
    fi
}

# Sync command: review and resolve conflicts
cmd_sync() {
    local project="$1"
    
    if [ -z "$project" ]; then
        echo "Error: sync requires <project>"
        echo "Usage: sofia-wiki sync <project>"
        exit 1
    fi
    
    local wiki_dir="$WIKI_ROOT/$project"
    
    if [ ! -d "$wiki_dir" ]; then
        echo "Error: Wiki not found for project: $project"
        exit 1
    fi
    
    echo "=== Sofia Wiki Sync: $project ==="
    echo ""
    
    # Use the database to get conflicts
    local conflicts_json=$("$SCRIPT_DIR/scripts/sofia-wiki-db" list-conflicts "$wiki_dir")
    local conflict_count=$(echo "$conflicts_json" | python3 -c "import json,sys; print(len(json.load(sys.stdin).get('conflicts',[])))" 2>/dev/null || echo 0)
    
    if [ "$conflict_count" = "0" ]; then
        echo "✓ No unresolved conflicts"
        echo ""
        echo "Wiki is in sync."
    else
        echo "Found $conflict_count unresolved conflict(s):"
        echo ""
        
        # Parse and display each conflict
        echo "$conflicts_json" | python3 -c "
import json, sys
data = json.load(sys.stdin)
for c in data.get('conflicts', []):
    print(f\"  [{c['id']}] {c['entity']} → {c['field']}\")
    print(f\"    Existing: {c['existing_chunk']}\")
    print(f\"    New:      {c['new_chunk']}\")
    print()
"
        echo "To resolve a conflict:"
        echo "  sofia-wiki resolve $project <conflict_id> <keep|new> [reason]"
        echo ""
        echo "To view chunk contents:"
        echo "  cat $wiki_dir/.sofia/chunks.json | jq '.chunks[\"<chunk_id>\"]'"
    fi
}

# Bulk analyze command: interactive LLM-in-the-loop processing
cmd_bulk_analyze() {
    local project="$1"
    local start_chapter="$2"
    
    if [ -z "$project" ]; then
        echo "Error: bulk-analyze requires <project>"
        echo "Usage: sofia-wiki bulk-analyze <project> [start_chapter]"
        exit 1
    fi
    
    local wiki_dir="$WIKI_ROOT/$project"
    local canon_dir="$CANON_ROOT/$project/chapters"
    
    if [ ! -d "$wiki_dir" ]; then
        echo "Error: Wiki not found for project: $project"
        exit 1
    fi
    
    if [ ! -d "$canon_dir" ]; then
        echo "Error: Canon chapters not found: $canon_dir"
        exit 1
    fi
    
    # Get list of pending chapters
    local pending_chapters=()
    local total=$(ls -1 "$canon_dir"/*.md 2>/dev/null | wc -l | tr -d ' ')
    
    for chapter_file in "$canon_dir"/*.md; do
        local basename=$(basename "$chapter_file" .md)
        local wiki_chapter="$wiki_dir/chapters/$basename.md"
        
        # Skip if wiki chapter already exists
        if [ ! -f "$wiki_chapter" ]; then
            pending_chapters+=("$basename")
        fi
    done
    
    local pending_count=${#pending_chapters[@]}
    
    echo "========================================"
    echo "SOFIA BULK ANALYZE: $project"
    echo "========================================"
    echo ""
    echo "Total chapters: $total"
    echo "Pending: $pending_count"
    echo "Already processed: $((total - pending_count))"
    echo ""
    
    if [ "$pending_count" -eq 0 ]; then
        echo "✓ All chapters have been analyzed!"
        echo ""
        echo "Run 'sofia-wiki status $project' to see entity counts."
        return 0
    fi
    
    echo "Pending chapters:"
    local i=1
    for ch in "${pending_chapters[@]}"; do
        echo "  $i. $ch"
        i=$((i + 1))
    done
    echo ""
    echo "========================================"
    echo "READY FOR ANALYSIS"
    echo "========================================"
    echo ""
    echo "To analyze the next chapter, run:"
    echo ""
    echo "  ./scripts/sofia-wiki extract $project ${pending_chapters[0]}"
    echo ""
    echo "This will output the extraction prompt. After you (the LLM) process it,"
    echo "save the response to:"
    echo ""
    echo "  $wiki_dir/chapters/${pending_chapters[0]}.md"
    echo ""
    echo "Then run this command again to continue with the next chapter."
    echo ""
    echo "========================================"
    echo "EXTRACTION PROMPT FOR: ${pending_chapters[0]}"
    echo "========================================"
    echo ""
    
    # Output the actual prompt for the first pending chapter
    "$SCRIPT_DIR/scripts/sofia-prompt" -extract "$canon_dir/${pending_chapters[0]}.md"
}

# Bulk extract command: generate prompts for all pending chapters
cmd_bulk_extract() {
    local project="$1"
    local output_dir="$2"
    local dry_run="$3"
    
    if [ -z "$project" ]; then
        echo "Error: bulk-extract requires <project>"
        echo "Usage: sofia-wiki bulk-extract <project> [output_dir]"
        exit 1
    fi
    
    local wiki_dir="$WIKI_ROOT/$project"
    local canon_dir="$CANON_ROOT/$project/chapters"
    
    if [ ! -d "$wiki_dir" ]; then
        echo "Error: Wiki not found for project: $project"
        exit 1
    fi
    
    if [ ! -d "$canon_dir" ]; then
        echo "Error: Canon chapters not found: $canon_dir"
        exit 1
    fi
    
    # Default output directory
    if [ -z "$output_dir" ]; then
        output_dir="$wiki_dir/prompts"
    fi
    
    echo "=== Sofia Wiki Bulk Extract: $project ==="
    echo ""
    
    # Create output directory
    mkdir -p "$output_dir"
    
    # Count chapters
    local total=$(ls -1 "$canon_dir"/*.md 2>/dev/null | wc -l | tr -d ' ')
    local processed=0
    local skipped=0
    
    echo "Canon chapters: $total"
    echo "Output directory: $output_dir"
    echo ""
    
    # Process each chapter
    for chapter_file in "$canon_dir"/*.md; do
        local basename=$(basename "$chapter_file" .md)
        local prompt_file="$output_dir/$basename-prompt.txt"
        local wiki_chapter="$wiki_dir/chapters/$basename.md"
        
        # Skip if wiki chapter already exists (already processed)
        if [ -f "$wiki_chapter" ]; then
            skipped=$((skipped + 1))
            continue
        fi
        
        if [ "$dry_run" = "true" ]; then
            echo "[DRY RUN] Would generate: $prompt_file"
        else
            echo "Generating: $basename..."
            "$SCRIPT_DIR/scripts/sofia-prompt" -extract "$chapter_file" > "$prompt_file"
        fi
        
        processed=$((processed + 1))
    done
    
    echo ""
    echo "=== Bulk Extract Complete ==="
    echo "Generated: $processed prompts"
    echo "Skipped (already in wiki): $skipped"
    echo ""
    
    if [ "$processed" -gt 0 ]; then
        echo "Prompts saved to: $output_dir/"
        echo ""
        echo "Next steps:"
        echo "  1. Send each prompt to your LLM"
        echo "  2. Save responses as wiki chapter pages"
        echo "  3. Run: sofia-wiki sync $project"
        echo ""
        echo "Batch processing options:"
        echo "  - Concatenate prompts: cat $output_dir/*-prompt.txt > all-prompts.txt"
        echo "  - Process with API: for f in $output_dir/*-prompt.txt; do ... done"
        echo ""
        
        # Calculate total word count
        local total_words=$(cat "$output_dir"/*-prompt.txt 2>/dev/null | wc -w | tr -d ' ')
        echo "Total words across all prompts: $total_words"
        echo "Estimated tokens: ~$((total_words * 4 / 3))"
    fi
}

# Update command: add new notes/chapters with LLM extraction
cmd_update() {
    local project="$1"
    local note_path="$2"
    local dry_run="$3"
    local no_commit="$4"
    
    if [ -z "$project" ] || [ -z "$note_path" ]; then
        echo "Error: update requires <project> and <note>"
        echo "Usage: sofia-wiki update <project> <note.md>"
        exit 1
    fi
    
    local wiki_dir="$WIKI_ROOT/$project"
    
    if [ ! -d "$wiki_dir" ]; then
        echo "Error: Wiki not found for project: $project"
        echo "Run 'sofia-wiki ingest $project <manuscript>' first"
        exit 1
    fi
    
    if [ ! -f "$note_path" ]; then
        echo "Error: Note not found: $note_path"
        exit 1
    fi
    
    echo "=== Sofia Wiki Update: $project ==="
    echo ""
    echo "Note: $note_path"
    echo ""
    
    # Step 1: Commit the incoming note
    if [ "$no_commit" != "true" ] && [ "$dry_run" != "true" ]; then
        echo "Step 1: Committing incoming note..."
        git add "$note_path" 2>/dev/null || true
        git commit -m "sofia: add incoming note $(basename "$note_path")" 2>/dev/null || echo "  (already committed or no changes)"
        echo ""
    fi
    
    # Step 2: Generate extraction prompt
    echo "Step 2: Generating extraction prompt..."
    echo ""
    
    local prompt_file="/tmp/sofia-update-prompt-$$.txt"
    "$SCRIPT_DIR/scripts/sofia-prompt" -extract "$note_path" > "$prompt_file"
    
    echo "Prompt saved to: $prompt_file"
    echo "Word count: $(wc -w < "$prompt_file" | tr -d ' ')"
    echo ""
    
    # Step 3: Instructions for user
    echo "Step 3: Send to LLM"
    echo ""
    echo "Option A - Copy to clipboard:"
    echo "  cat $prompt_file | pbcopy"
    echo ""
    echo "Option B - View prompt:"
    echo "  cat $prompt_file"
    echo ""
    echo "Step 4: After LLM responds, save entities to wiki:"
    echo "  - Create/update wiki pages in $wiki_dir/people/, places/, etc."
    echo "  - Run: sofia-wiki sync $project"
    echo ""
    
    # Offer to copy to clipboard
    if command -v pbcopy &> /dev/null; then
        echo "Copy prompt to clipboard now? [y/N]"
        read -r response
        if [ "$response" = "y" ] || [ "$response" = "Y" ]; then
            cat "$prompt_file" | pbcopy
            echo "✓ Prompt copied to clipboard"
        fi
    fi
    
    echo ""
    echo "=== Update prepared ==="
}

# Resolve command: resolve a specific conflict
cmd_resolve() {
    local project="$1"
    local conflict_id="$2"
    local choice="$3"
    local reason="$4"
    
    if [ -z "$project" ] || [ -z "$conflict_id" ] || [ -z "$choice" ]; then
        echo "Error: resolve requires <project> <conflict_id> <keep|new>"
        echo "Usage: sofia-wiki resolve <project> <conflict_id> <keep|new> [reason]"
        exit 1
    fi
    
    local wiki_dir="$WIKI_ROOT/$project"
    
    # Get conflict details
    local conflicts_json=$("$SCRIPT_DIR/scripts/sofia-wiki-db" list-conflicts "$wiki_dir")
    local existing_chunk=$(echo "$conflicts_json" | python3 -c "
import json, sys
data = json.load(sys.stdin)
for c in data.get('conflicts', []):
    if c['id'] == '$conflict_id':
        print(c['existing_chunk'])
        break
")
    local new_chunk=$(echo "$conflicts_json" | python3 -c "
import json, sys
data = json.load(sys.stdin)
for c in data.get('conflicts', []):
    if c['id'] == '$conflict_id':
        print(c['new_chunk'])
        break
")
    
    if [ -z "$existing_chunk" ]; then
        echo "Error: Conflict not found: $conflict_id"
        exit 1
    fi
    
    # Determine which chunk to keep
    local chosen_chunk
    case "$choice" in
        keep|existing|old)
            chosen_chunk="$existing_chunk"
            ;;
        new|incoming)
            chosen_chunk="$new_chunk"
            ;;
        *)
            echo "Error: choice must be 'keep' or 'new'"
            exit 1
            ;;
    esac
    
    # Resolve the conflict
    local result=$("$SCRIPT_DIR/scripts/sofia-wiki-db" resolve-conflict "$wiki_dir" "$conflict_id" "$chosen_chunk" "$reason")
    echo "$result"
    
    echo ""
    echo "Conflict resolved. Run 'sofia-wiki sync $project' to verify."
}

# ============================================================================
# New Commands: loop, entities, validate, align
# ============================================================================

# Loop command: LLM-in-the-loop workflow
cmd_loop() {
    local project="$1"
    
    if [ -z "$project" ]; then
        if [ "$JSON_OUTPUT" = "true" ]; then
            emit_json "Error: loop requires <project>" "null" '{"error": "missing_project"}' "" "false"
        else
            echo "Error: loop requires <project>"
            echo "Usage: sofia-wiki loop <project>"
        fi
        exit 1
    fi
    
    local wiki_dir="$WIKI_ROOT/$project"
    local canon_dir="$CANON_ROOT/$project/chapters"
    
    if [ ! -d "$wiki_dir" ]; then
        if [ "$JSON_OUTPUT" = "true" ]; then
            emit_json "Wiki not found for project: $project. Run 'sofia-wiki ingest' first." "null" "{\"error\": \"wiki_not_found\", \"project\": \"$project\"}" "" "false"
        else
            echo "Error: Wiki not found for project: $project"
            echo "Run 'sofia-wiki ingest $project <manuscript>' first"
        fi
        exit 1
    fi
    
    # Get counts
    local canon_chapters=$(ls -1 "$canon_dir"/*.md 2>/dev/null | wc -l | tr -d ' ')
    local wiki_chapters=$(ls -1 "$wiki_dir/chapters"/*.md 2>/dev/null | grep -v index.md | wc -l | tr -d ' ')
    local pending=$((canon_chapters - wiki_chapters))
    
    # Find next pending chapter
    local next_chapter=""
    if [ "$pending" -gt 0 ]; then
        next_chapter=$(ls -1 "$canon_dir"/*.md 2>/dev/null | while read f; do
            bn=$(basename "$f" .md)
            if [ ! -f "$wiki_dir/chapters/$bn.md" ]; then
                echo "$bn"
                break
            fi
        done)
    fi
    
    # Load known entities from registry
    local entities_json="[]"
    if [ -f "$wiki_dir/.sofia/entities.json" ]; then
        entities_json=$(python3 -c "
import json
with open('$wiki_dir/.sofia/entities.json') as f:
    data = json.load(f)
    names = list(data.get('entities', {}).keys())
    print(json.dumps(names[:50]))  # Limit to 50 for prompt size
" 2>/dev/null || echo "[]")
    fi
    
    if [ "$JSON_OUTPUT" = "true" ]; then
        local data_json="{\"stage\": \"loop\", \"project\": \"$project\", \"canon_chapters\": $canon_chapters, \"wiki_chapters\": $wiki_chapters, \"pending\": $pending, \"next_chapter\": \"$next_chapter\", \"known_entities\": $entities_json}"
        
        if [ "$pending" -eq 0 ]; then
            # All chapters done - suggest validation
            emit_status_json "All $canon_chapters chapters extracted. Ready for validation." "$data_json" "sofia-wiki validate $project --json"
        else
            # Chapters pending - emit extraction prompt
            local prompt=$("$SCRIPT_DIR/scripts/sofia-prompt" -extract "$canon_dir/$next_chapter.md" 2>/dev/null | head -c 50000)
            # Escape the prompt for JSON
            local escaped_prompt=$(echo "$prompt" | python3 -c "import json,sys; print(json.dumps(sys.stdin.read()))")
            
            local data_with_prompt="{\"stage\": \"extract\", \"project\": \"$project\", \"chapter\": \"$next_chapter\", \"pending\": $pending, \"prompt\": $escaped_prompt, \"known_entities\": $entities_json, \"output_path\": \"$wiki_dir/chapters/$next_chapter.md\"}"
            
            emit_status_json "Extract chapter $next_chapter ($pending remaining). Process the prompt and save to output_path." "$data_with_prompt" "sofia-wiki loop $project --json"
        fi
    else
        echo "=== Sofia Wiki Loop: $project ==="
        echo ""
        echo "Canon chapters: $canon_chapters"
        echo "Wiki chapters:  $wiki_chapters"
        echo "Pending:        $pending"
        echo ""
        
        if [ "$pending" -eq 0 ]; then
            echo "✓ All chapters extracted!"
            echo ""
            echo "Next: sofia-wiki validate $project"
        else
            echo "Next chapter: $next_chapter"
            echo ""
            echo "Run with --json for LLM-in-the-loop mode:"
            echo "  sofia-wiki loop $project --json"
        fi
    fi
}

# Entities command: list known entity names
cmd_entities() {
    local project="$1"
    
    if [ -z "$project" ]; then
        echo "Error: entities requires <project>"
        echo "Usage: sofia-wiki entities <project>"
        exit 1
    fi
    
    local wiki_dir="$WIKI_ROOT/$project"
    
    if [ ! -d "$wiki_dir" ]; then
        echo "Error: Wiki not found for project: $project"
        exit 1
    fi
    
    local entities_file="$wiki_dir/.sofia/entities.json"
    
    # Build entity list from wiki files if registry is empty/missing
    if [ ! -f "$entities_file" ] || [ "$(cat "$entities_file" | python3 -c "import json,sys; print(len(json.load(sys.stdin).get('entities',{})))")" = "0" ]; then
        # Scan wiki files to build entity registry
        python3 << 'PYEOF'
import os
import json
import re

wiki_dir = os.environ.get('WIKI_DIR', 'notes/wiki/error-correction')
entities = {}

# Scan each entity category
for category in ['people', 'places', 'events', 'objects', 'ideas']:
    cat_dir = os.path.join(wiki_dir, category)
    if not os.path.isdir(cat_dir):
        continue
    
    for fname in os.listdir(cat_dir):
        if not fname.endswith('.md') or fname == 'index.md':
            continue
        
        fpath = os.path.join(cat_dir, fname)
        with open(fpath, 'r') as f:
            content = f.read()
        
        # Extract title from first H1 or H2
        match = re.search(r'^#+ (.+)$', content, re.MULTILINE)
        if match:
            name = match.group(1).strip()
            slug = fname[:-3]  # remove .md
            entities[name] = {
                'slug': slug,
                'category': category,
                'file': fpath
            }

# Also scan chapter files for entity mentions
chapters_dir = os.path.join(wiki_dir, 'chapters')
if os.path.isdir(chapters_dir):
    for fname in os.listdir(chapters_dir):
        if not fname.endswith('.md'):
            continue
        fpath = os.path.join(chapters_dir, fname)
        with open(fpath, 'r') as f:
            content = f.read()
        
        # Find H3 headers under People, Places, etc sections
        for match in re.finditer(r'^### (.+)$', content, re.MULTILINE):
            name = match.group(1).strip()
            if name and name not in entities:
                entities[name] = {'slug': None, 'category': 'unknown', 'file': None}

# Save to registry
registry = {'version': '1.0', 'entities': entities}
entities_file = os.path.join(wiki_dir, '.sofia', 'entities.json')
os.makedirs(os.path.dirname(entities_file), exist_ok=True)
with open(entities_file, 'w') as f:
    json.dump(registry, f, indent=2)

print(f"Found {len(entities)} entities")
PYEOF
    fi
    
    if [ "$JSON_OUTPUT" = "true" ]; then
        cat "$entities_file"
    else
        echo "=== Entity Registry: $project ==="
        echo ""
        python3 -c "
import json
with open('$entities_file') as f:
    data = json.load(f)
    entities = data.get('entities', {})
    
    # Group by category
    by_cat = {}
    for name, info in entities.items():
        cat = info.get('category', 'unknown')
        if cat not in by_cat:
            by_cat[cat] = []
        by_cat[cat].append(name)
    
    for cat in ['people', 'places', 'events', 'objects', 'ideas', 'unknown']:
        if cat in by_cat:
            print(f'{cat.title()} ({len(by_cat[cat])}):')
            for name in sorted(by_cat[cat])[:20]:
                print(f'  - {name}')
            if len(by_cat[cat]) > 20:
                print(f'  ... and {len(by_cat[cat]) - 20} more')
            print()
"
    fi
}

# Validate command: check entity naming consistency
cmd_validate() {
    local project="$1"
    local chapter="$2"
    
    if [ -z "$project" ]; then
        echo "Error: validate requires <project>"
        echo "Usage: sofia-wiki validate <project> [chapter]"
        exit 1
    fi
    
    local wiki_dir="$WIKI_ROOT/$project"
    
    if [ ! -d "$wiki_dir" ]; then
        echo "Error: Wiki not found for project: $project"
        exit 1
    fi
    
    # Run validation
    local validation_result=$(python3 << 'PYEOF'
import os
import json
import re
from collections import defaultdict

wiki_dir = os.environ.get('WIKI_DIR', 'notes/wiki/error-correction')
chapter_filter = os.environ.get('CHAPTER_FILTER', '')

# Load entity registry
entities_file = os.path.join(wiki_dir, '.sofia', 'entities.json')
known_entities = {}
if os.path.exists(entities_file):
    with open(entities_file) as f:
        known_entities = json.load(f).get('entities', {})

# Find all entity mentions in wiki chapters
mentions = defaultdict(list)  # name -> [files where mentioned]
chapters_dir = os.path.join(wiki_dir, 'chapters')

if os.path.isdir(chapters_dir):
    for fname in os.listdir(chapters_dir):
        if not fname.endswith('.md'):
            continue
        if chapter_filter and chapter_filter not in fname:
            continue
            
        fpath = os.path.join(chapters_dir, fname)
        with open(fpath, 'r') as f:
            content = f.read()
        
        # Find H3 headers (entity names)
        for match in re.finditer(r'^### (.+)$', content, re.MULTILINE):
            name = match.group(1).strip()
            mentions[name].append(fname)

# Find potential duplicates (similar names)
import difflib

warnings = []
errors = []
variants = defaultdict(list)

names = list(mentions.keys())
for i, name1 in enumerate(names):
    for name2 in names[i+1:]:
        # Check similarity
        ratio = difflib.SequenceMatcher(None, name1.lower(), name2.lower()).ratio()
        if ratio > 0.8 and ratio < 1.0:
            # Potential variant
            # Determine canonical (most frequent or in registry)
            if name1 in known_entities:
                canonical = name1
                variant = name2
            elif name2 in known_entities:
                canonical = name2
                variant = name1
            else:
                # Use most frequent
                if len(mentions[name1]) >= len(mentions[name2]):
                    canonical = name1
                    variant = name2
                else:
                    canonical = name2
                    variant = name1
            
            variants[canonical].append({
                'variant': variant,
                'similarity': round(ratio, 2),
                'files': mentions[variant]
            })

# Check for broken links
for fname in os.listdir(chapters_dir) if os.path.isdir(chapters_dir) else []:
    if not fname.endswith('.md'):
        continue
    fpath = os.path.join(chapters_dir, fname)
    with open(fpath, 'r') as f:
        content = f.read()
    
    # Find markdown links
    for match in re.finditer(r'\[([^\]]+)\]\(([^)]+)\)', content):
        link_text, link_path = match.groups()
        if link_path.startswith('../'):
            # Relative link to entity
            full_path = os.path.normpath(os.path.join(chapters_dir, link_path))
            if not os.path.exists(full_path) and not link_path.startswith('http'):
                warnings.append({
                    'type': 'broken_link',
                    'file': fname,
                    'link': link_path,
                    'text': link_text
                })

result = {
    'project': os.path.basename(wiki_dir),
    'variants': dict(variants),
    'warnings': warnings,
    'errors': errors,
    'entity_count': len(known_entities),
    'mention_count': len(mentions)
}

print(json.dumps(result, indent=2))
PYEOF
)
    
    export WIKI_DIR="$wiki_dir"
    export CHAPTER_FILTER="$chapter"
    
    local variant_count=$(echo "$validation_result" | python3 -c "import json,sys; print(len(json.load(sys.stdin).get('variants',{})))")
    local warning_count=$(echo "$validation_result" | python3 -c "import json,sys; print(len(json.load(sys.stdin).get('warnings',[])))")
    
    if [ "$JSON_OUTPUT" = "true" ]; then
        local data_json=$(echo "$validation_result" | python3 -c "
import json,sys
data = json.load(sys.stdin)
data['stage'] = 'validate'
print(json.dumps(data))
")
        
        if [ "$variant_count" -gt 0 ]; then
            # Has variants - ask for decision
            emit_ask_json \
                "Validation found $variant_count entity name variants and $warning_count warnings." \
                "choice" \
                "How to handle name variants?" \
                '["align-all", "review-each", "skip"]' \
                "align-all" \
                "$data_json" \
                "sofia-wiki align $project --auto --json"
        else
            emit_status_json "Validation passed. No entity name variants found. $warning_count warnings." "$data_json" ""
        fi
    else
        echo "=== Validation: $project ==="
        echo ""
        echo "$validation_result" | python3 -c "
import json,sys
data = json.load(sys.stdin)

variants = data.get('variants', {})
warnings = data.get('warnings', [])

if variants:
    print(f'Entity Name Variants ({len(variants)}):')
    for canonical, vars in variants.items():
        print(f'  {canonical}:')
        for v in vars:
            print(f'    - {v[\"variant\"]} ({v[\"similarity\"]*100:.0f}% similar, in {len(v[\"files\"])} files)')
    print()

if warnings:
    print(f'Warnings ({len(warnings)}):')
    for w in warnings[:10]:
        if w['type'] == 'broken_link':
            print(f'  - Broken link in {w[\"file\"]}: {w[\"link\"]}')
    if len(warnings) > 10:
        print(f'  ... and {len(warnings) - 10} more')
    print()

if not variants and not warnings:
    print('✓ No issues found')
"
    fi
}

# Apply previous_names auto-alignment to content
# Returns the content with previous names replaced by canonical names
apply_previous_names() {
    local wiki_dir="$1"
    local content="$2"
    
    python3 << PYEOF
import json
import os
import re

wiki_dir = "$wiki_dir"
content = '''$content'''
entities_file = os.path.join(wiki_dir, '.sofia', 'entities.json')

if not os.path.exists(entities_file):
    print(content)
    exit()

with open(entities_file) as f:
    registry = json.load(f)

previous_names = registry.get('previous_names', {})

if not previous_names:
    print(content)
    exit()

# Apply each previous name replacement
changes = []
for old_name, info in previous_names.items():
    canonical = info.get('canonical', '')
    if canonical and old_name in content:
        content = content.replace(old_name, canonical)
        changes.append(f"{old_name} -> {canonical}")

# Log changes to stderr so they don't pollute the output
if changes:
    import sys
    print(f"Auto-aligned {len(changes)} previous names: {', '.join(changes)}", file=sys.stderr)

print(content)
PYEOF
}

# Check if content contains any previous names and return alignment info
check_previous_names() {
    local wiki_dir="$1"
    local content="$2"
    
    python3 << PYEOF
import json
import os

wiki_dir = "$wiki_dir"
content = '''$content'''
entities_file = os.path.join(wiki_dir, '.sofia', 'entities.json')

if not os.path.exists(entities_file):
    print(json.dumps({"found": [], "count": 0}))
    exit()

with open(entities_file) as f:
    registry = json.load(f)

previous_names = registry.get('previous_names', {})
found = []

for old_name, info in previous_names.items():
    if old_name in content:
        found.append({
            "old": old_name,
            "canonical": info.get('canonical', ''),
            "deprecated": info.get('deprecated', ''),
            "reason": info.get('reason', '')
        })

print(json.dumps({"found": found, "count": len(found)}))
PYEOF
}

# Register a previous name in the entity registry
register_previous_name() {
    local wiki_dir="$1"
    local old_name="$2"
    local canonical_name="$3"
    local reason="${4:-Author name change}"
    
    local entities_file="$wiki_dir/.sofia/entities.json"
    
    python3 << PYEOF
import json
import os
from datetime import datetime

entities_file = "$entities_file"
old_name = "$old_name"
canonical_name = "$canonical_name"
reason = "$reason"

# Load or create registry
if os.path.exists(entities_file):
    with open(entities_file) as f:
        registry = json.load(f)
else:
    registry = {"version": "1.0", "entities": {}, "previous_names": {}}

# Ensure previous_names section exists
if "previous_names" not in registry:
    registry["previous_names"] = {}

# Add the previous name mapping
registry["previous_names"][old_name] = {
    "canonical": canonical_name,
    "deprecated": datetime.now().strftime("%Y-%m-%d"),
    "reason": reason
}

# Save registry
os.makedirs(os.path.dirname(entities_file), exist_ok=True)
with open(entities_file, 'w') as f:
    json.dump(registry, f, indent=2)

print(f"Registered '{old_name}' as previous name for '{canonical_name}'")
PYEOF
}

# Deprecate command: register a previous name (alias for align --deprecate)
cmd_deprecate() {
    local project="$1"
    local old_name="$2"
    local canonical_name="$3"
    
    if [ -z "$project" ] || [ -z "$old_name" ]; then
        echo "Error: deprecate requires <project> and <old_name>"
        echo "Usage: sofia-wiki deprecate <project> <old_name> [--canonical <new_name>]"
        echo ""
        echo "If --canonical is not provided, will search for similar names in registry."
        exit 1
    fi
    
    local wiki_dir="$WIKI_ROOT/$project"
    
    if [ ! -d "$wiki_dir" ]; then
        echo "Error: Wiki not found for project: $project"
        exit 1
    fi
    
    # If canonical name provided, register directly
    if [ -n "$canonical_name" ]; then
        register_previous_name "$wiki_dir" "$old_name" "$canonical_name"
        
        if [ "$JSON_OUTPUT" = "true" ]; then
            emit_status_json "Registered '$old_name' as previous name for '$canonical_name'." "{\"stage\": \"deprecate\", \"old\": \"$old_name\", \"canonical\": \"$canonical_name\"}" ""
        fi
    else
        # Try to find a similar canonical name in registry
        local suggestion=$(python3 << PYEOF
import json
import os
import difflib

wiki_dir = "$wiki_dir"
old_name = "$old_name"
entities_file = os.path.join(wiki_dir, '.sofia', 'entities.json')

if not os.path.exists(entities_file):
    print("")
    exit()

with open(entities_file) as f:
    registry = json.load(f)

entities = registry.get('entities', {})
names = []
for eid, edata in entities.items():
    if isinstance(edata, dict) and 'name' in edata:
        names.append(edata['name'])
    elif isinstance(edata, str):
        names.append(edata)

# Find best match
best_match = None
best_ratio = 0
for name in names:
    ratio = difflib.SequenceMatcher(None, old_name.lower(), name.lower()).ratio()
    if ratio > best_ratio and ratio > 0.6:
        best_ratio = ratio
        best_match = name

if best_match:
    print(best_match)
else:
    print("")
PYEOF
)
        
        if [ -n "$suggestion" ]; then
            echo "Found similar name: $suggestion"
            echo ""
            echo "Register '$old_name' as previous name for '$suggestion'? [y/N]"
            read -r response
            if [ "$response" = "y" ] || [ "$response" = "Y" ]; then
                register_previous_name "$wiki_dir" "$old_name" "$suggestion"
            fi
        else
            echo "No similar name found in registry."
            echo "Please specify canonical name: sofia-wiki deprecate $project '$old_name' --canonical '<canonical_name>'"
        fi
    fi
}

# Align command: correct entity name variants
cmd_align() {
    local project="$1"
    local old_name="$2"
    local new_name="$3"
    local deprecate="$DEPRECATE_FLAG"
    
    if [ -z "$project" ]; then
        echo "Error: align requires <project>"
        echo "Usage: sofia-wiki align <project> <old_name> <new_name> [--deprecate]"
        echo "       sofia-wiki align <project> --auto"
        exit 1
    fi
    
    local wiki_dir="$WIKI_ROOT/$project"
    
    if [ ! -d "$wiki_dir" ]; then
        echo "Error: Wiki not found for project: $project"
        exit 1
    fi
    
    # Auto mode: align all detected variants
    if [ "$old_name" = "--auto" ]; then
        # Run validation to get variants
        export WIKI_DIR="$wiki_dir"
        local validation=$(WIKI_DIR="$wiki_dir" python3 << 'PYEOF'
import os
import json
import re
from collections import defaultdict
import difflib

wiki_dir = os.environ.get('WIKI_DIR')
chapters_dir = os.path.join(wiki_dir, 'chapters')

# Load entity registry
entities_file = os.path.join(wiki_dir, '.sofia', 'entities.json')
known_entities = {}
if os.path.exists(entities_file):
    with open(entities_file) as f:
        known_entities = json.load(f).get('entities', {})

# Find all entity mentions
mentions = defaultdict(list)
if os.path.isdir(chapters_dir):
    for fname in os.listdir(chapters_dir):
        if not fname.endswith('.md'):
            continue
        fpath = os.path.join(chapters_dir, fname)
        with open(fpath, 'r') as f:
            content = f.read()
        for match in re.finditer(r'^### (.+)$', content, re.MULTILINE):
            name = match.group(1).strip()
            mentions[name].append(fname)

# Find variants
variants = []
names = list(mentions.keys())
for i, name1 in enumerate(names):
    for name2 in names[i+1:]:
        ratio = difflib.SequenceMatcher(None, name1.lower(), name2.lower()).ratio()
        if ratio > 0.8 and ratio < 1.0:
            if name1 in known_entities:
                canonical, variant = name1, name2
            elif name2 in known_entities:
                canonical, variant = name2, name1
            elif len(mentions[name1]) >= len(mentions[name2]):
                canonical, variant = name1, name2
            else:
                canonical, variant = name2, name1
            variants.append({'canonical': canonical, 'variant': variant, 'files': mentions[variant]})

print(json.dumps(variants))
PYEOF
)
        
        local change_count=0
        
        # Apply each variant correction
        echo "$validation" | python3 -c "
import json,sys,os,re

wiki_dir = os.environ.get('WIKI_DIR')
variants = json.load(sys.stdin)
chapters_dir = os.path.join(wiki_dir, 'chapters')

changes = 0
for v in variants:
    canonical = v['canonical']
    variant = v['variant']
    
    for fname in v['files']:
        fpath = os.path.join(chapters_dir, fname)
        with open(fpath, 'r') as f:
            content = f.read()
        
        # Replace variant with canonical in H3 headers
        new_content = re.sub(
            rf'^### {re.escape(variant)}$',
            f'### {canonical}',
            content,
            flags=re.MULTILINE
        )
        
        if new_content != content:
            with open(fpath, 'w') as f:
                f.write(new_content)
            changes += 1
            print(f'  {fname}: {variant} -> {canonical}')

print(f'\\nAligned {changes} occurrences')
"
        
        if [ "$JSON_OUTPUT" = "true" ]; then
            emit_status_json "Auto-aligned entity name variants." '{"stage": "align", "mode": "auto"}' "git add $wiki_dir && git commit -m 'sofia: align entity names'"
        fi
    else
        # Manual mode: align specific name
        if [ -z "$new_name" ]; then
            echo "Error: align requires <old_name> and <new_name>"
            echo "Usage: sofia-wiki align <project> <old_name> <new_name> [--deprecate]"
            exit 1
        fi
        
        # Find and replace in all wiki files
        local changes=$(find "$wiki_dir" -name "*.md" -exec grep -l "$old_name" {} \; | while read f; do
            if grep -q "$old_name" "$f"; then
                sed -i '' "s/$old_name/$new_name/g" "$f"
                echo "$f"
            fi
        done | wc -l | tr -d ' ')
        
        # If --deprecate flag is set, register old name as previous_name
        if [ "$deprecate" = "true" ]; then
            register_previous_name "$wiki_dir" "$old_name" "$new_name"
        fi
        
        if [ "$JSON_OUTPUT" = "true" ]; then
            local deprecate_info=""
            [ "$deprecate" = "true" ] && deprecate_info=", \"deprecated\": true"
            emit_status_json "Aligned '$old_name' to '$new_name' in $changes files.${deprecate:+ Registered as previous name.}" "{\"stage\": \"align\", \"old\": \"$old_name\", \"new\": \"$new_name\", \"changes\": $changes$deprecate_info}" "git add $wiki_dir && git commit -m 'sofia: align $old_name to $new_name'"
        else
            echo "Aligned '$old_name' to '$new_name' in $changes files."
            if [ "$deprecate" = "true" ]; then
                echo "Registered '$old_name' as previous name for '$new_name'."
            fi
            echo ""
            echo "Run: git add $wiki_dir && git commit -m 'sofia: align entity names'"
        fi
    fi
}

# Parse arguments
COMMAND=""
PROJECT=""
ARG2=""
ARG3=""
ARG4=""
DRY_RUN="false"
NO_COMMIT="false"
DEPRECATE_FLAG="false"
CANONICAL_NAME=""

while [ $# -gt 0 ]; do
    case "$1" in
        --json)
            JSON_OUTPUT="true"
            shift
            ;;
        --dry-run)
            DRY_RUN="true"
            shift
            ;;
        --no-commit)
            NO_COMMIT="true"
            shift
            ;;
        --deprecate)
            DEPRECATE_FLAG="true"
            shift
            ;;
        --canonical)
            CANONICAL_NAME="$2"
            shift 2
            ;;
        -h|--help)
            show_usage
            exit 0
            ;;
        ingest|update|sync|status|extract|resolve|bulk-extract|bulk-analyze|loop|entities|validate|align|deprecate)
            COMMAND="$1"
            shift
            ;;
        *)
            if [ -z "$PROJECT" ]; then
                PROJECT="$1"
            elif [ -z "$ARG2" ]; then
                ARG2="$1"
            elif [ -z "$ARG3" ]; then
                ARG3="$1"
            elif [ -z "$ARG4" ]; then
                ARG4="$1"
            fi
            shift
            ;;
    esac
done

if [ -z "$COMMAND" ]; then
    show_usage
    exit 1
fi

# Change to script directory for relative paths
cd "$SCRIPT_DIR"

case "$COMMAND" in
    ingest)
        cmd_ingest "$PROJECT" "$ARG2" "$DRY_RUN" "$NO_COMMIT"
        ;;
    extract)
        cmd_extract "$PROJECT" "$ARG2"
        ;;
    status)
        cmd_status "$PROJECT"
        ;;
    sync)
        cmd_sync "$PROJECT"
        ;;
    resolve)
        cmd_resolve "$PROJECT" "$ARG2" "$ARG3" "$ARG4"
        ;;
    bulk-extract)
        cmd_bulk_extract "$PROJECT" "$ARG2" "$DRY_RUN"
        ;;
    bulk-analyze)
        cmd_bulk_analyze "$PROJECT" "$ARG2"
        ;;
    update)
        cmd_update "$PROJECT" "$ARG2" "$DRY_RUN" "$NO_COMMIT"
        ;;
    loop)
        cmd_loop "$PROJECT"
        ;;
    entities)
        cmd_entities "$PROJECT"
        ;;
    validate)
        cmd_validate "$PROJECT" "$ARG2"
        ;;
    align)
        cmd_align "$PROJECT" "$ARG2" "$ARG3"
        ;;
    deprecate)
        # Use CANONICAL_NAME if provided via --canonical, otherwise use ARG3
        cmd_deprecate "$PROJECT" "$ARG2" "${CANONICAL_NAME:-$ARG3}"
        ;;
    *)
        echo "Unknown command: $COMMAND"
        show_usage
        exit 1
        ;;
esac
